{
  "expo": {
    "name": "家庭记账本",
    "slug": "family-budget-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "budgetapp",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e17"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.familybudget.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "用于导入账单截图",
        "NSCameraUsageDescription": "用于拍照导入账单"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0e17"
      },
      "package": "com.familybudget.app"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ]
  }
}
